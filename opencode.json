{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "agent/skills/drive16-app-builder.md"
  ],
  "permission": {
    "skill": "deny"
  },
  "agent": {
    "drive16-build": {
      "description": "One bounded Drive16 ROM implementation pass",
      "mode": "primary",
      "steps": 20,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0,
      "permission": {
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "drive16-repair": {
      "description": "One targeted Drive16 repair pass after a specific failed check",
      "mode": "primary",
      "steps": 16,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0,
      "permission": {
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "bakeoff": {
      "description": "Bounded Drive16 model comparison runs",
      "mode": "primary",
      "steps": 20,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0,
      "permission": {
        "drive16-comfyui_*": "deny",
        "drive16-rag_*": "deny",
        "drive16-mml-music_*": "deny",
        "task": "deny",
        "todowrite": "deny"
      }
    },
    "drive16-implement": {
      "description": "Phased pass 1: requested gameplay to a verified first build",
      "mode": "primary",
      "steps": 20,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0,
      "permission": {
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "deny",
        "drive16-comfyui_*": "deny",
        "drive16-mml-music_*": "deny"
      }
    },
    "drive16-art": {
      "description": "Phased pass 2: generate, wire, and verify sprites for the primary roles",
      "mode": "primary",
      "steps": 16,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0.4,
      "permission": {
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "deny",
        "drive16-mml-music_*": "deny",
        "drive16-rag_*": "deny"
      }
    },
    "drive16-music": {
      "description": "Phased pass 3: compose, wire, and verify the soundtrack end to end",
      "mode": "primary",
      "steps": 16,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0.4,
      "permission": {
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "deny",
        "drive16-comfyui_*": "deny"
      }
    },
    "drive16-polish": {
      "description": "Phased pass 4: fix verification findings and finish project memory",
      "mode": "primary",
      "steps": 12,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0,
      "permission": {
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "deny",
        "drive16-comfyui_*": "deny",
        "drive16-mml-music_*": "deny"
      }
    },
    "drive16-iterate": {
      "description": "Fast bounded iteration on the current game: one focused change, build, scoped verify",
      "mode": "primary",
      "steps": 12,
      "max_tokens": 3500,
      "maxOutputTokens": 3500,
      "temperature": 0,
      "permission": {
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "deny",
        "drive16-comfyui_*": "deny",
        "drive16-mml-music_*": "deny",
        "drive16-rag_*": "deny"
      }
    }
  },
  "provider": {
    "ollama": {
      "name": "Ollama local",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "minimax-m2.5:cloud": {
          "name": "MiniMax M2.5 Cloud"
        },
        "rafw007/Qwen3.6-35B-A3B-mlx-claude-coder-abliterated:latest": {
          "name": "Qwen 3.6 35B Claude Coder MLX",
          "options": {
            "reasoningEffort": "none"
          }
        },
        "gemma4:31b-it-qat": {
          "name": "Gemma 4 31B IT QAT"
        },
        "gpt-oss:120b": {
          "name": "GPT-OSS 120B"
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "mcp": {
    "drive16-sgdk-build": {
      "type": "local",
      "command": [
        "python3",
        "mcp-servers/sgdk-build/server.py"
      ],
      "enabled": true
    },
    "drive16-emulator": {
      "type": "local",
      "command": [
        "python3",
        "mcp-servers/emulator/server.py"
      ],
      "enabled": true
    },
    "drive16-rag": {
      "type": "local",
      "command": [
        "scripts/mcp-local-rag.sh"
      ],
      "environment": {
        "BASE_DIR": ".",
        "CACHE_DIR": "artifacts/phase1/rag/models",
        "DB_PATH": "artifacts/phase1/rag/lancedb",
        "MODEL_NAME": "Xenova/all-MiniLM-L6-v2"
      },
      "enabled": true
    },
    "drive16-comfyui": {
      "type": "local",
      "command": [
        "python3",
        "mcp-servers/comfyui/server.py"
      ],
      "environment": {
        "COMFYUI_DOWNLOAD_CACHE_DIR": "artifacts/phase4/comfyui-mcp/cache"
      },
      "enabled": true
    },
    "drive16-mml-music": {
      "type": "local",
      "command": [
        "python3",
        "mcp-servers/mml-music/server.py"
      ],
      "enabled": true
    }
  }
}