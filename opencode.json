{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "drive16-sgdk-build": {
      "type": "local",
      "command": [
        "python3",
        "mcp-servers/sgdk-build/server.py"
      ],
      "enabled": true
    },
    "drive16-emulator": {
      "type": "local",
      "command": [
        "python3",
        "mcp-servers/emulator/server.py"
      ],
      "enabled": true
    },
    "drive16-rag": {
      "type": "local",
      "command": [
        "scripts/mcp-local-rag.sh"
      ],
      "environment": {
        "BASE_DIR": ".",
        "CACHE_DIR": "artifacts/phase1/rag/models",
        "DB_PATH": "artifacts/phase1/rag/lancedb",
        "MODEL_NAME": "Xenova/all-MiniLM-L6-v2"
      },
      "enabled": true
    }
  }
}
