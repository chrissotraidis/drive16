+    fn write_frame_stream_record(
+        &self,
+        file: &mut std::fs::File,
+        frame_index: u64,
+    ) -> std::io::Result<()> {
+        use std::io::Write;
+
+        let bus = self.bus.borrow();
+        let fb = &bus.vdp.framebuffer;
+        file.write_all(b"D16F")?;
+        file.write_all(&1u16.to_le_bytes())?;
+        file.write_all(&320u16.to_le_bytes())?;
+        file.write_all(&240u16.to_le_bytes())?;
+        file.write_all(&565u16.to_le_bytes())?;
+        file.write_all(&frame_index.to_le_bytes())?;
+        file.write_all(&((fb.len() * 2) as u32).to_le_bytes())?;
+        for &pixel in fb {
+            file.write_all(&pixel.to_le_bytes())?;
+        }
+        Ok(())
+    }
