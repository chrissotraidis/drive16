{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drive16",
  "version": "0.1.0",
  "identifier": "dev.drive16.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Drive16",
        "width": 1440,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
